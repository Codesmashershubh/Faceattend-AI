# MongoDB Atlas connection string (free tier - https://www.mongodb.com/cloud/atlas/register)
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/faceattend?retryWrites=true&w=majority

# Long random string used to sign JWTs
JWT_SECRET=replace_with_a_long_random_secret

# Port the Express server listens on
PORT=5000

# URL where the Python AI recognition server is running
AI_SERVER_URL=http://localhost:8000

# Comma separated list of origins allowed to call this API
CLIENT_ORIGIN=http://localhost:5173
